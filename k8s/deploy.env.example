# Copy to deploy.env (gitignored) and adjust for your registry / tags.
#
#   cp k8s/deploy.env.example k8s/deploy.env

# --- TLS / HTTPS (Let's Encrypt via cert-manager) ---
# Hostname, TLS Secret name, and ClusterIssuer are in ssl-params.env.
# Edit k8s/ssl-params.env before kubectl apply -k k8s/
#
# Fields:
#   INGRESS_HOST          — DNS name on your certificate (must match Ingress rules + TLS host)
#   TLS_SECRET_NAME       — Kubernetes Secret cert-manager writes (referenced by Ingress.spec.tls)
#   CERT_CLUSTER_ISSUER   — cert-manager ClusterIssuer resource name (e.g. letsencrypt-prod)
#
# Flow:
#   ./k8s/install-ingress-nginx.sh
#   Point DNS A record at: kubectl get svc -n ingress-nginx ingress-nginx-controller -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
#   kubectl apply -k k8s/

IMAGE_REGISTRY=registry.digitalocean.com/storefront-obs-registry
BACKEND_REPO=backend
FRONTEND_REPO=frontend
BACKEND_TAG=latest
FRONTEND_TAG=latest

# Must match the docker-registry Secret you create in the namespace:
#   kubectl create secret docker-registry registry-docr \
#     --docker-server=registry.digitalocean.com \
#     --docker-username=digitalocean_oauth \
#     --docker-password="$DIGITALOCEAN_ACCESS_TOKEN" \
#     -n storefront-obs
IMAGE_PULL_SECRET_NAME=registry-docr
