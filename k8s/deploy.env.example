# Copy to deploy.env (gitignored) and adjust for your registry / tags.
# Used by apply.sh when present; you can also edit kustomization.yaml -> images:
#
#   cp k8s/deploy.env.example k8s/deploy.env

IMAGE_REGISTRY=registry.digitalocean.com/storefront-obs-registry
BACKEND_REPO=backend
FRONTEND_REPO=frontend
BACKEND_TAG=latest
FRONTEND_TAG=latest

# Must match the docker-registry Secret you create in the namespace:
#   kubectl create secret docker-registry registry-docr \
#     --docker-server=registry.digitalocean.com \
#     --docker-username=digitalocean_oauth \
#     --docker-password="$DIGITALOCEAN_ACCESS_TOKEN" \
#     -n storefront-obs
IMAGE_PULL_SECRET_NAME=registry-docr
